# The webhook signing secret = the `plain_secret` returned ONCE when you create
# the endpoint. Leave empty to skip signature verification.
WEBHOOK_SECRET=

# Address to bind. 127.0.0.1 locally; Docker sets 0.0.0.0 so the mapped port works.
HOST=127.0.0.1

# Local port the server listens on (the tunnel forwards to it).
PORT=5000

# Set to false to serve locally only, with no tunnel (e.g. behind your own).
USE_TUNNEL=true

# cloudflared edge transport. http2 (TCP 443) works on networks that block QUIC's
# outbound UDP 7844; set to `quic` or `auto` only if your network allows UDP 7844.
TUNNEL_PROTOCOL=http2
